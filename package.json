{
  "name": "eklavya-healthcare-centre",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x || 22.x"
  },
  "scripts": {
    "generate-favicons": "node tools/generate-favicons.js",
    "dev": "next dev",
    "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-Process node -ErrorAction SilentlyContinue | Stop-Process -Force; if (Test-Path .next) { Remove-Item .next -Recurse -Force }; next dev -p 3000\"",
    "lint": "next lint",
    "build": "next build",
    "start": "next start",
    "sass": "sass --load-path=node_modules --no-source-map src/assets/scss:public/css"
  },
  "dependencies": {
    "png-to-ico": "^1.0.0",
    "sharp": "^0.32.0",
    "@popperjs/core": "^2.11.8",
    "@vercel/analytics": "^2.0.1",
    "animate.css": "^4.1.1",
    "bootstrap": "^5.3.8",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.8.0",
    "next": "^15.5.15",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "sass": "^1.99.0"
  }
}
